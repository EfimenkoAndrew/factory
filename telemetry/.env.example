# Host-port overrides for the AI Factory telemetry stack (copy to .env to change).
# Defaults match the spine's Structural Seed; override when a port clashes locally.

# Stack identity (KI-E25). Only needed when a SECOND host repo on the same machine runs its
# own stack: `docker compose -p` cannot override container_name, and the project name scopes
# the prometheus-data/grafana-data volumes — so without these two, host B collides with host A
# on container names and silently shares host A's volumes. Change BOTH (and the ports below).
FACTORY_COMPOSE_PROJECT=ai-factory-telemetry
FACTORY_CONTAINER_PREFIX=factory

FACTORY_GRAFANA_PORT=3000
FACTORY_PROM_PORT=9090
FACTORY_EXPORTER_PORT=9464
FACTORY_OTLP_GRPC_PORT=4317
FACTORY_OTLP_HTTP_PORT=4318
FACTORY_SPANMETRICS_PORT=8889
FACTORY_GRAFANA_ADMIN_PASSWORD=factory-local-admin
