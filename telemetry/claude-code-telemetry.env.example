# Claude Code cost telemetry → the factory collector (KI-E28).
#
# The dashboard's two cost panels — "Claude Code token rate by type" and "Prompt-cache hit
# ratio" — read claude_code_token_usage_tokens_total, which ONLY the Claude Code session emits.
# The collector already accepts it (otel-collector.yaml: the metrics pipeline has an `otlp`
# receiver; :4318 is exposed), so the only missing piece is telling YOUR Claude Code session to
# push there. Without this the two panels are permanently empty — not broken, just unconfigured.
#
# Point the endpoint at the collector's HTTP OTLP port on THIS host:
#   - single-host default stack : http://localhost:4318
#   - a KI-E25 second stack     : http://localhost:${FACTORY_OTLP_HTTP_PORT}  (e.g. 4418)
#
# Use it by sourcing this file in the shell that launches the factory's Claude Code session
# (`set -a; . telemetry/claude-code-telemetry.env; set +a`), or copy these into your shell profile.
# Cost observability is the factory's central concern (EFFECTIVENESS.md) — this is what lights it up.

CLAUDE_CODE_ENABLE_TELEMETRY=1
OTEL_METRICS_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Optional: default export interval is 60s; drop it so the panels move during a run.
OTEL_METRIC_EXPORT_INTERVAL=10000
