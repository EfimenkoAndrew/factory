{
 "uid": "ai-factory",
 "title": "AI Factory",
 "tags": [
  "ai-factory",
  "telemetry"
 ],
 "timezone": "browser",
 "schemaVersion": 39,
 "refresh": "30s",
 "time": {
  "from": "now-24h",
  "to": "now"
 },
 "panels": [
  {
   "id": 1,
   "type": "stat",
   "title": "Items by lifecycle state",
   "gridPos": {
    "h": 6,
    "w": 12,
    "x": 0,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (state) (factory_items)",
     "legendFormat": "{{state}}",
     "instant": true
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "textMode": "value_and_name",
    "colorMode": "background"
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "blue",
        "value": null
       }
      ]
     }
    },
    "overrides": [
     {
      "matcher": {
       "id": "byName",
       "options": "CLOSED"
      },
      "properties": [
       {
        "id": "color",
        "value": {
         "mode": "fixed",
         "fixedColor": "green"
        }
       }
      ]
     },
     {
      "matcher": {
       "id": "byName",
       "options": "FAILED"
      },
      "properties": [
       {
        "id": "color",
        "value": {
         "mode": "fixed",
         "fixedColor": "red"
        }
       }
      ]
     },
     {
      "matcher": {
       "id": "byName",
       "options": "BLOCKED"
      },
      "properties": [
       {
        "id": "color",
        "value": {
         "mode": "fixed",
         "fixedColor": "orange"
        }
       }
      ]
     }
    ]
   }
  },
  {
   "id": 2,
   "type": "stat",
   "title": "Stream freshness (s since last event)",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 12,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "time() - factory_last_event_timestamp_seconds"
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value"
   },
   "fieldConfig": {
    "defaults": {
     "unit": "s",
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "orange",
        "value": 3600
       },
       {
        "color": "red",
        "value": 21600
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 3,
   "type": "stat",
   "title": "Infra-suspect results",
   "gridPos": {
    "h": 6,
    "w": 6,
    "x": 18,
    "y": 0
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "factory_infra_failures_total"
    }
   ],
   "options": {
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    },
    "colorMode": "value"
   },
   "fieldConfig": {
    "defaults": {
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "green",
        "value": null
       },
       {
        "color": "orange",
        "value": 1
       },
       {
        "color": "red",
        "value": 5
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 4,
   "type": "timeseries",
   "title": "Folds by outcome (per hour)",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (tostate) (increase(factory_item_folds_total[1h]))",
     "legendFormat": "{{tostate}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "custom": {
      "drawStyle": "bars",
      "fillOpacity": 60,
      "stacking": {
       "mode": "normal"
      }
     },
     "unit": "short"
    },
    "overrides": [
     {
      "matcher": {
       "id": "byName",
       "options": "CLOSED"
      },
      "properties": [
       {
        "id": "color",
        "value": {
         "mode": "fixed",
         "fixedColor": "green"
        }
       }
      ]
     },
     {
      "matcher": {
       "id": "byName",
       "options": "FAILED"
      },
      "properties": [
       {
        "id": "color",
        "value": {
         "mode": "fixed",
         "fixedColor": "red"
        }
       }
      ]
     }
    ]
   }
  },
  {
   "id": 5,
   "type": "timeseries",
   "title": "Stage duration p95 (derived \u2014 the duration authority)",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 6
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "histogram_quantile(0.95, sum by (stage, le) (rate(factory_stage_duration_seconds_bucket[6h])))",
     "legendFormat": "{{stage}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "s",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    },
    "overrides": []
   }
  },
  {
   "id": 6,
   "type": "bargauge",
   "title": "Gate approval rate",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 0,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (gate) (factory_gate_verdicts_total{verdict=\"APPROVED\"}) / sum by (gate) (factory_gate_verdicts_total)",
     "legendFormat": "{{gate}}",
     "instant": true
    }
   ],
   "options": {
    "displayMode": "gradient",
    "orientation": "horizontal",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   },
   "fieldConfig": {
    "defaults": {
     "unit": "percentunit",
     "min": 0,
     "max": 1,
     "thresholds": {
      "mode": "absolute",
      "steps": [
       {
        "color": "red",
        "value": null
       },
       {
        "color": "orange",
        "value": 0.6
       },
       {
        "color": "green",
        "value": 0.85
       }
      ]
     }
    },
    "overrides": []
   }
  },
  {
   "id": 7,
   "type": "bargauge",
   "title": "Agent-call volume by model",
   "gridPos": {
    "h": 8,
    "w": 12,
    "x": 12,
    "y": 14
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (model) (factory_agent_calls_total)",
     "legendFormat": "{{model}}",
     "instant": true
    }
   ],
   "options": {
    "displayMode": "gradient",
    "orientation": "horizontal",
    "reduceOptions": {
     "calcs": [
      "lastNotNull"
     ]
    }
   },
   "fieldConfig": {
    "defaults": {
     "unit": "short"
    },
    "overrides": []
   }
  },
  {
   "id": 8,
   "type": "timeseries",
   "title": "Event rate by source (5m)",
   "gridPos": {
    "h": 7,
    "w": 12,
    "x": 0,
    "y": 22
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (source) (rate(factory_events_total[5m]))",
     "legendFormat": "{{source}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "ops",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    },
    "overrides": []
   }
  },
  {
   "id": 9,
   "type": "timeseries",
   "title": "Span-derived stage latency p90 (collector spanmetrics)",
   "gridPos": {
    "h": 7,
    "w": 12,
    "x": 12,
    "y": 22
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "histogram_quantile(0.90, sum by (span_name, le) (rate(traces_span_metrics_duration_seconds_bucket[6h])))",
     "legendFormat": "{{span_name}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "s",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    },
    "overrides": []
   }
  },
  {
   "id": 10,
   "type": "timeseries",
   "title": "Claude Code token rate by type (5m) \u2014 needs CLAUDE_CODE_ENABLE_TELEMETRY sessions",
   "gridPos": {
    "h": 7,
    "w": 12,
    "x": 0,
    "y": 29
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum by (type) (rate(claude_code_token_usage_tokens_total[5m]))",
     "legendFormat": "{{type}}"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "cps",
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    },
    "overrides": []
   }
  },
  {
   "id": 11,
   "type": "timeseries",
   "title": "Prompt-cache hit ratio (cacheRead / all input-side tokens, 5m)",
   "gridPos": {
    "h": 7,
    "w": 12,
    "x": 12,
    "y": 29
   },
   "datasource": {
    "type": "prometheus",
    "uid": "prometheus-factory"
   },
   "targets": [
    {
     "refId": "A",
     "expr": "sum(rate(claude_code_token_usage_tokens_total{type=\"cacheRead\"}[5m])) / sum(rate(claude_code_token_usage_tokens_total{type=~\"cacheRead|cacheCreation|input\"}[5m]))",
     "legendFormat": "cache hit ratio"
    }
   ],
   "fieldConfig": {
    "defaults": {
     "unit": "percentunit",
     "min": 0,
     "max": 1,
     "custom": {
      "drawStyle": "line",
      "fillOpacity": 10
     }
    },
    "overrides": []
   }
  }
 ]
}